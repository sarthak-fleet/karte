---
// Card IV — The assistant.
//
// Astro port of /src/components/landing/onyx-agents.tsx.
//
// Compromise vs the Next.js original: the React version opens an inline
// waitlist form that AJAX-POSTs to /api/agent-waitlist. That can't work
// statically without shipping client JS — a native form POST would dump
// raw JSON in the browser, which is a worse UX than what we have now.
// Until the agent-subtype flow ships (docs/plans/agent-subtype-spec.md),
// the static port renders only the "Coming soon" CTA and funnels it to
// /create (Card V already collects signups; post-cutover the Worker
// owns /create, so the link still resolves). See landing-astro/README.
---

<div class="onyx-agents">
  <div class="onyx-agents-left">
    <div class="onyx-eyebrow">·  ISSUED → YOUR INBOUND  ·</div>
    <h2 class="onyx-h2">
      Your assistant
      <br />
      <em>takes the first pass.</em>
    </h2>
    <p class="onyx-agents-p">
      It answers the obvious questions, asks for the missing context, and
      keeps the awkward cold outreach out of your real inbox until there is
      something worth reading.
    </p>

    <div class="onyx-agents-actions">
      <a href="/create" class="onyx-btn-primary">
        Claim your inbound agent <span aria-hidden="true">→</span>
      </a>
    </div>
    <p class="onyx-agents-waitlist-msg">
      Start with your public page. Add links, memory, inbox, and contact
      routing as soon as you claim the handle.
    </p>
  </div>

  <div class="onyx-agents-right">
    <div class="onyx-agent-mini">
      <div class="onyx-agent-mini-foil" aria-hidden="true"></div>
      <div class="onyx-agent-mini-top">
        <span>INBOUND DESK</span>
        <span>№ a-0042</span>
      </div>
      <div class="onyx-agent-mini-mid">
        <div class="onyx-agent-mini-avatar" aria-hidden="true">○</div>
        <div class="onyx-agent-mini-name">Karte Agent</div>
        <div class="onyx-agent-mini-rule" aria-hidden="true"></div>
        <div class="onyx-agent-mini-role">
          <em>Inbound assistant · first pass</em>
        </div>
      </div>
      <div class="onyx-agent-spec">
        <div>
          <b>reply</b>
          <span>availability · rates · links · FAQs</span>
        </div>
        <div>
          <b>intent</b>
          <span>intent · email · project context</span>
        </div>
        <div>
          <b>route</b>
          <span>only the messages worth your time</span>
        </div>
      </div>
      <div class="onyx-agent-mini-bot">
        <span>karte.cc / yourname</span>
        <span>ISSUED → INBOUND</span>
      </div>
    </div>
  </div>
</div>
