---
// Card I — Hero.
//
// Carries the brand wordplay while positioning Karte as an inbound
// assistant, not another generic page builder.
//
// Astro port of /src/components/landing/onyx-hero.tsx. PostHog click
// capture is intentionally NOT ported — analytics is a known gap on
// the static landing-astro deploy; the Next.js Worker keeps every
// other route, so post-cutover funnel events still fire downstream.
// /create lives on the Next.js Worker and is reachable cross-origin
// once Pages serves `/`.
---

<div class="onyx-hero">
  <div class="onyx-eyebrow">
    <span class="onyx-eyebrow-dot" aria-hidden="true"></span>
    The public agent for your inbound
  </div>

  <h1 class="onyx-hero-h1">
    Everyone gets
    <br />
    <em>an agent.</em>
  </h1>

  <p class="onyx-hero-etymology">
    <span class="gold">karte</span>
    {' '}<span class="gold">·</span> <span class="gold">/ˈkartə/</span>
    {' '}— German for card. <em>This one handles inbound.</em>
  </p>

  <p class="onyx-hero-sub">
    Movie stars have agents to filter calls, questions, and opportunities.
    Karte gives that first-pass assistant to every public page: answers,
    context, and cleaner handoffs before anything hits your inbox.
  </p>

  <div class="onyx-hero-actions">
    <a href="/create" class="onyx-btn-primary">
      Claim your name <span aria-hidden="true">→</span>
    </a>
    <a href="/sarthak" class="onyx-btn-ghost">
      See it live <span aria-hidden="true">↗</span>
    </a>
  </div>

  <div class="onyx-hero-fine">
    Free · no card · 60-second import from Linktree, Carrd, Beacons, or Bento.
  </div>
</div>
