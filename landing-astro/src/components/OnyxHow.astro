---
// Card II — How it works.
//
// Three Roman-numeral steps with leader rule, gold gradient numerals.
// Astro port of /src/components/landing/onyx-how.tsx — pure static
// markup, no behaviour delta.
const STEPS = [
  {
    i: 'I',
    t: 'Teach it your public life',
    b: 'Links, projects, FAQs, rates, boundaries.',
  },
  {
    i: 'II',
    t: 'Set the inbound brief',
    b: 'What to answer, what to collect, what to route.',
  },
  {
    i: 'III',
    t: 'Share one public agent',
    b: 'Visitors ask first. Your inbox gets the cleaner version.',
  },
] as const;
---

<div class="onyx-how">
  <div class="onyx-eyebrow center">·  HOW IT WORKS  ·</div>
  <h2 class="onyx-h2 center">
    Your agent is live <em>before lunch.</em>
  </h2>
  <div class="onyx-how-grid">
    {STEPS.map((s) => (
      <div class="onyx-how-step">
        <div class="onyx-how-num">{s.i}</div>
        <div class="onyx-how-rule" aria-hidden="true"></div>
        <div class="onyx-how-title">{s.t}</div>
        <div class="onyx-how-body">{s.b}</div>
      </div>
    ))}
  </div>
</div>
